@using Glazecs.Modules.ASR.Abstractions.Interfaces
@using Glazecs.Shared.UI.Components
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@page "/modules/asr/speech_recognition"

<MudContainer @onkeydown="OnPageKeyDown" MaxWidth="MaxWidth.False" Class="mt-4">
    <MudStack Spacing="3">

        <!-- Панель управления -->
        <MudCard Outlined="true">
            <MudCardContent>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudSelect T="ISpeechRecognitionService"
                               Value="_selectedService"
                               Disabled="@(_isProcessing || _isInitializing)"
                               Placeholder="@L["ASR_Service_Label"]"
                               Variant="Variant.Outlined"
                               Style="min-width: 200px;"
                               ValueChanged="OnServiceChanged">
                        @foreach (var service in SpeechServices)
                        {
                            <MudSelectItem T="ISpeechRecognitionService" Value="@service">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudText>@service.Name</MudText>
                                    @if (!string.IsNullOrWhiteSpace(service.Description))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @service.Description
                                        </MudText>
                                    }
                                </MudStack>
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <PathPickerComponent @bind-Value="_filePath"
                                         Disabled="@(_isProcessing || _isInitializing)"
                                         IsFolder="false"
                                         Placeholder="@L["ASR_FilePath_Placeholder"]"
                                         TooltipText="@L["ASR_Tooltip_Select_File"]"
                                         Icon="@Icons.Material.Filled.Attachment"
                                         IconStyle="width: 56px; height: 56px;"
                                         FileTypes="_audioFileTypes" />

                    @if (!_isProcessing && !_isInitializing)
                    {
                        @if (_selectedService != null && !_selectedService.Initialized)
                        {
                            <MudTooltip Text="@L["ASR_Tooltip_Initialize"]">
                                <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                                               Variant="Variant.Filled"
                                               Color="Color.Info"
                                               Style="width: 56px; height: 56px;"
                                               OnClick="InitializeServiceAsync" />
                            </MudTooltip>
                        }

                        <MudTooltip Text="@L["ASR_Tooltip_Start"]">
                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Style="width: 56px; height: 56px;"
                                           OnClick="StartRecognitionAsync"
                                           Disabled="@(string.IsNullOrWhiteSpace(_filePath) || _selectedService == null || !_selectedService.Initialized)" />
                        </MudTooltip>
                    }
                    else if (_isProcessing)
                    {
                        <MudTooltip Text="@L["ASR_Tooltip_Cancel"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop"
                                           Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Style="width: 56px; height: 56px;"
                                           OnClick="CancelRecognition" />
                        </MudTooltip>
                    }
                    else if (_isInitializing)
                    {
                        <MudTooltip Text="@L["ASR_Tooltip_Cancel"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop"
                                           Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Style="width: 56px; height: 56px;"
                                           OnClick="CancelInitializing" />
                        </MudTooltip>
                    }
                </MudStack>

                <!-- UI для отображения прогресса инициализации -->
                @if (_isInitializing)
                {
                    <MudStack Spacing="1" Class="mt-4">
                        <MudText Typo="Typo.body2" Color="Color.Info">
                            @_initProgressMessage
                        </MudText>
                        <MudProgressLinear Color="Color.Info"
                                           Value="@_initProgressPercent"
                                           Style="height: 8px;" />
                    </MudStack>
                }

                <!-- UI для отображения прогресса распознавания -->
                @if (_isProcessing)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
                        <MudText Typo="Typo.body2" Style="min-width: 150px;">
                            @L["ASR_Processing"]: <strong>@_processedChunksCount</strong> @L["ASR_Chunks"]
                        </MudText>
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="flex-grow: 1;" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        <!-- Область результатов -->
        <MudCard Outlined="true">
            <MudCardContent Class="pa-4">
                @if (string.IsNullOrWhiteSpace(_resultText))
                {
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="text-center">
                        @L["ASR_No_Result_Yet"]
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">
                        @_resultText
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudStack>
</MudContainer>