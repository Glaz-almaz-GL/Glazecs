@using Glazecs.Modules.FileChunker.Abstractions.Interfaces
@using Glazecs.Modules.FileChunker.Resources.Languages
@using Glazecs.Shared.Core.Extensions
@using Microsoft.Extensions.Localization
@using MudBlazor
@inject IEnumerable<IFileChunker> FileChunkers
@inject ISnackbar Snackbar
@inject IStringLocalizer<FileChunkerResources> L
@page "/modules/file-chunker/document_chunker"

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudGrid>
        <!-- Основная панель настроек -->
        <MudItem xs="12" md="9">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">@L["PageTitle"]</MudText>

                <MudGrid>
                    <!-- Выбор формата обработки -->
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string"
                                   @bind-Value="_selectedFormat"
                                   Label="@L["FormatLabel"]"
                                   Variant="Variant.Outlined"
                                   HelperText="@L["FormatHelper"]">
                            <MudSelectItem Value="@("word")">@L["FormatWord"]</MudSelectItem>
                            <MudSelectItem Value="@("pdf")">@L["FormatPdf"]</MudSelectItem>
                            <MudSelectItem Value="@("all")">@L["FormatAll"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <!-- Выходная директория -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_outputDirectory"
                                      Label="@L["OutputDirectoryLabel"]"
                                      Placeholder="@L["OutputDirectoryPlaceholder"]"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                                      AdornmentColor="@Color.Secondary"
                                      OnAdornmentClick="SelectOutputFolder"
                                      HelperText="@L["OutputDirectoryHelper"]" />
                    </MudItem>

                    <!-- Исходная папка с файлами -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_sourceDirectory"
                                      Label="@L["SourceDirectoryLabel"]"
                                      Placeholder="@L["SourceDirectoryPlaceholder"]"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                                      AdornmentColor="@Color.Primary"
                                      OnAdornmentClick="SelectSourceFolder"
                                      HelperText="@L["SourceDirectoryHelper"]" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudCheckBox T="bool"
                                     @bind-Value="_scanSubfolders"
                                     Label="@L["ScanSubfoldersLabel"]"
                                     Color="Color.Secondary" />
                    </MudItem>

                    <!-- Размер чанка и шаблон -->
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="long"
                                         @bind-Value="_maxChunkSizeMB"
                                         Label="@L["MaxChunkSizeLabel"]"
                                         Min="1"
                                         Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="_headerTemplate"
                                      Label="@L["HeaderTemplateLabel"]"
                                      Placeholder="@L["HeaderTemplatePlaceholder"]"
                                      Lines="5"
                                      MaxLines="5"
                                      Variant="Variant.Outlined" />

                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 mb-1">
                            @L["PlaceholdersCaption"]
                        </MudText>

                        <MudChipSet T="string" Size="Size.Medium">
                            @foreach (var placeholder in _placeholders)
                            {
                                <MudChip T="string"
                                         Text="@placeholder.Key"
                                         Color="Color.Info"
                                         Variant="Variant.Outlined"
                                         Size="Size.Small"
                                         Style="cursor: pointer;"
                                         OnClick="@(() => InsertPlaceholder(placeholder.Key))">
                                    <MudTooltip Text="@placeholder.Description" Placement="Placement.Top">
                                        @placeholder.Key
                                    </MudTooltip>
                                </MudChip>
                            }
                        </MudChipSet>
                    </MudItem>

                    <!-- Правила обработки -->
                    <MudItem xs="12">
                        <MudDivider />
                        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">@L["RulesSectionTitle"]</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" @bind-Value="_removePunctuation" Label="@L["RemovePunctuationLabel"]" Color="Color.Secondary" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" @bind-Value="_useStopWords" Label="@L["UseStopWordsLabel"]" Color="Color.Secondary" />
                            </MudItem>
                        </MudGrid>

                        @if (_useStopWords)
                        {
                            <MudTextField @bind-Value="_stopWordsText"
                                          Label="@L["StopWordsLabel"]"
                                          Variant="Variant.Outlined"
                                          Class="mt-2"
                                          HelperText="@L["StopWordsHelper"]" />
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Список найденных файлов -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="height: 100%;">
                <MudGrid>
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.FolderSpecial"
                                   OnClick="ScanSourceFolder"
                                   FullWidth="true"
                                   Disabled="@string.IsNullOrWhiteSpace(_sourceDirectory)">
                            @L["ScanButton"]
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6" Class="mb-2">
                            @L["FoundFilesTitle"] (@_selectedFiles.Count)
                        </MudText>
                    </MudItem>
                </MudGrid>

                @if (_selectedFiles.Any())
                {
                    <MudTable Items="_selectedFiles"
                              Hover="true"
                              Striped="true"
                              Dense="true"
                              Style="max-height: 500px; overflow-y: auto;">
                        <HeaderContent>
                            <MudTh Style="width: 40px;">№</MudTh>
                            <MudTh>@L["ColumnFileName"]</MudTh>
                            <MudTh Style="width: 40px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="№">@(_selectedFiles.IndexOf(context) + 1)</MudTd>
                            <MudTd DataLabel="@L["ColumnFileName"]">
                                <MudText Typo="Typo.body2" Style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@context.Path">
                                    @context.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.Extension (@context.Size.ToHumanReadableSize())
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="">
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveFile(context))"
                                               title="@L["RemoveFileTitle"]" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center">
                        @L["NoFilesFound"]
                    </MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- Кнопки управления -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudGrid Justify="Justify.FlexEnd">
                    <MudItem>

                        @if (!_isProcessing)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Disabled="@(_isProcessing || _selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(_outputDirectory))"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       OnClick="ProcessFiles">
                                @L["ProcessButton"]
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Disabled="@(_isProcessing || _selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(_outputDirectory))"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       OnClick="CancelProcessing">
                                @L["CancelButton"]
                            </MudButton>
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Результаты обработки -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">@L["ResultsTitle"]</MudText>
                <MudTable Items="_results"
                          Hover="true"
                          Striped="true"
                          Dense="true"
                          Outlined="true"
                          Elevation="0"
                          Loading="@_isProcessing"
                          LoadingProgressColor="Color.Primary">
                    <HeaderContent>
                        <MudTh>@L["ColumnFileName"]</MudTh>
                        <MudTh>@L["ColumnSize"]</MudTh>
                        <MudTh>@L["ColumnSourceFiles"]</MudTh>
                        <MudTh>@L["ColumnPath"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["ColumnFileName"]">@context.OutputFileName</MudTd>
                        <MudTd DataLabel="@L["ColumnSize"]">@context.SizeInBytes.ToHumanReadableSize()</MudTd>
                        <MudTd DataLabel="@L["ColumnSourceFiles"]">
                            <MudText Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@string.Join(", ", context.SourceFileNames)">
                                @string.Join(", ", context.SourceFileNames)
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="@L["ColumnPath"]">
                            <MudTooltip Text="@context.OutputPath">
                                <MudText Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @System.IO.Path.GetFileName(context.OutputPath)
                                </MudText>
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText>@L["NoResults"]</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<MudOverlay Visible="@_isProcessing" LockScroll="true">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    <MudText Typo="Typo.h6" Class="mt-4">@L["ProcessingOverlay"]</MudText>
</MudOverlay>