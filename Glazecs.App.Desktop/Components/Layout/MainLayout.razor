@using Glazecs.App.Desktop.Resources.Languages
@using Glazecs.Shared.UI.Interfaces
@using Glazecs.Shared.UI.Models
@using Microsoft.Extensions.Localization
@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject IAppSettingsService AppSettings
@inject IStringLocalizer<DesktopResources> L

@* Required *@
<MudThemeProvider @ref="_mudThemeProvider" Theme="_customTheme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Dense="true"
               Elevation="1"
               Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />

        <MudText Typo="Typo.h5" Class="ml-3">Glazecs</MudText>
        <MudSpacer />

        <!-- Переключатель языка -->
        <MudFabMenu StartIcon="@Icons.Material.Filled.Language"
                    Direction="Direction.Bottom"
                    Color="Color.Secondary"
                    Size="Size.Small"
                    Class="mr-2">

            <MudFabMenuItem StartIcon="@Icons.Material.Filled.Translate"
                            Color="Color.Primary"
                            Size="Size.Small"
                            title="Русский"
                            OnClick="async () => { await ToggleCultureAsync(RussianCulture); }" />

            <MudFabMenuItem StartIcon="@Icons.Material.Filled.Translate"
                            Color="Color.Primary"
                            Size="Size.Small"
                            title="English"
                            OnClick="async () => { await ToggleCultureAsync(EnglishCulture); }" />

        </MudFabMenu>

        <!-- Переключатель темы -->
        <MudFabMenu StartIcon="@Icons.Material.Filled.Mode"
                    Direction="Direction.Bottom"
                    Color="Color.Secondary"
                    Size="Size.Small">
            <MudFabMenuItem StartIcon="@Icons.Material.Filled.DarkMode"
                            Color="Color.Primary"
                            Size="Size.Small"
                            title="@L["Theme_Dark"]"
                            OnClick="async () => { await ToggleThemeAsync(ThemeMode.Dark); }" />

            <MudFabMenuItem StartIcon="@Icons.Material.Filled.LightMode"
                            Color="Color.Primary"
                            Size="Size.Small"
                            title="@L["Theme_Light"]"
                            OnClick="async () => { await ToggleThemeAsync(ThemeMode.Light); }" />

            <MudFabMenuItem StartIcon="@Icons.Material.Filled.AutoMode"
                            Color="Color.Primary"
                            Size="Size.Small"
                            title="@L["Theme_System"]"
                            OnClick="async () => { await ToggleThemeAsync(ThemeMode.System); }" />
        </MudFabMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>

        </MudDrawerHeader>
        <MudDrawerContainer>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home">
                @L["Page_Home"]
            </MudNavLink>
            <MudNavGroup Expanded="true"
                         Icon="@Icons.Material.Filled.PieChart"
                         Title="@L["Group_Modules"]">
                <MudNavGroup Expanded="true"
                             Icon="@Icons.Material.Filled.FilePresent"
                             Title="FMMS">
                    <MudNavLink Href="/modules/fmms/files_scanner" Icon="@Icons.Material.Filled.Dashboard">
                        @L["Page_Fmms_Files_Scanner"]
                    </MudNavLink>

                    <MudNavLink Href="/modules/fmms/directory_scanner" Icon="@Icons.Material.Filled.FilterNone">
                        @L["Page_Fmms_Directory_Scanner"]
                    </MudNavLink>
                </MudNavGroup>
                <MudNavLink Href="/modules/file-chunker/document_chunker" Icon="@Icons.Custom.FileFormats.FileDocument">
                    @L["Page_FC_Document_Chunker"]
                </MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/settings" Icon="@Icons.Custom.FileFormats.FileDocument">
                @L["Page_Settings"]
            </MudNavLink>
        </MudDrawerContainer>
    </MudDrawer>

    <MudMainContent>
        <div style="padding:10px;">
            @Body
        </div>
    </MudMainContent>
</MudLayout>