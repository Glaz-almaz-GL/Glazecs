@using Glazecs.Modules.FileChunker.Abstractions.Interfaces
@using Glazecs.Shared.Core.Extensions
@using MudBlazor
@inject IFileChunker FileChunker
@inject ISnackbar Snackbar
@page "/modules/file-chunker/word"

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudGrid>
        <!-- Основная панель настроек -->
        <MudItem xs="12" md="9">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Настройки чанкинга файлов</MudText>

                <MudGrid>
                    <!-- Выходная директория -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_outputDirectory"
                                      Label="Выходная директория"
                                      Placeholder="Введите путь или выберите папку"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                                      AdornmentColor="@Color.Secondary"
                                      OnAdornmentClick="SelectOutputFolder"
                                      HelperText="Можно ввести путь вручную или выбрать папку кнопкой справа" />
                    </MudItem>

                    <!-- Размер чанка и шаблон -->
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="long"
                                         @bind-Value="_maxChunkSizeMB"
                                         Label="Макс. размер чанка (МБ)"
                                         Min="1"
                                         Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_headerTemplate"
                                      Label="Шаблон заголовка"
                                      Placeholder="{FileName} - Part {FilePart}"
                                      Variant="Variant.Outlined" />

                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 mb-1">
                            Доступные плейсхолдеры (нажмите для вставки):
                        </MudText>

                        <MudChipSet T="string" Dense="true">
                            @foreach (var placeholder in _placeholders)
                            {
                                <MudChip T="string"
                                         Text="@placeholder.Key"
                                         Color="Color.Info"
                                         Variant="Variant.Outlined"
                                         Size="Size.Small"
                                         Style="cursor: pointer;"
                                         OnClick="@(() => InsertPlaceholder(placeholder.Key))">
                                    <MudTooltip Text="@placeholder.Description" Placement="Placement.Top">
                                        @placeholder.Key
                                    </MudTooltip>
                                </MudChip>
                            }
                        </MudChipSet>
                    </MudItem>

                    <!-- Правила обработки -->
                    <MudItem xs="12">
                        <MudDivider/>
                        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Правила обработки</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" @bind-Value="_removePunctuation" Label="Удалить знаки препинания" Color="Color.Secondary" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudCheckBox T="bool" @bind-Value="_useStopWords" Label="Применить фильтр стоп-слов" Color="Color.Secondary" />
                            </MudItem>
                        </MudGrid>

                        @if (_useStopWords)
                        {
                            <MudTextField @bind-Value="_stopWordsText"
                                          Label="Стоп-слова (через запятую)"
                                          Variant="Variant.Outlined"
                                          Class="mt-2"
                                          HelperText="Введите слова через запятую" />
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Список выбранных файлов -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4">
                    Выбранные файлы (@_selectedFiles.Count)
                </MudText>

                @if (_selectedFiles.Any())
                {
                    <MudTable Items="_selectedFiles"
                              Hover="true"
                              Striped="true"
                              Dense="true"
                              Style="max-height: 500px; overflow-y: auto;">
                        <HeaderContent>
                            <MudTh Style="width: 40px;">№</MudTh>
                            <MudTh>Имя файла</MudTh>
                            <MudTh Style="width: 40px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="№">@(_selectedFiles.IndexOf(context) + 1)</MudTd>
                            <MudTd DataLabel="Имя файла">
                                <MudText Typo="Typo.body2" Style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" Title="@context.Name">
                                    @context.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.Extension (@context.Size.ToHumanReadableSize())
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="">
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveFile(context))"
                                               Title="Удалить из списка" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center">
                        Файлы не выбраны
                    </MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- Кнопки управления -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudGrid Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudItem>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="SelectFiles"
                                   Size="Size.Large">
                            Добавить файлы (.docx)
                        </MudButton>
                    </MudItem>
                    <MudItem Class="ml-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   Disabled="@(_isProcessing || _selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(_outputDirectory))"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="ProcessFiles">
                            Запустить обработку
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        <!-- Результаты обработки -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-4">Результаты обработки</MudText>
                <MudTable Items="_results"
                          Hover="true"
                          Striped="true"
                          Dense="true"
                          Outlined="true"
                          Elevation="0"
                          Loading="@_isProcessing"
                          LoadingProgressColor="Color.Primary">
                    <HeaderContent>
                        <MudTh>Имя файла</MudTh>
                        <MudTh>Размер</MudTh>
                        <MudTh>Исходные файлы</MudTh>
                        <MudTh>Путь</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Имя файла">@context.OutputFileName</MudTd>
                        <MudTd DataLabel="Размер">@context.SizeInBytes.ToHumanReadableSize()</MudTd>
                        <MudTd DataLabel="Исходные файлы">
                            <MudText Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" Title="@string.Join(", ", context.SourceFileNames)">
                                @string.Join(", ", context.SourceFileNames)
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="Путь">
                            <MudTooltip Text="@context.OutputPath">
                                <MudText Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @System.IO.Path.GetFileName(context.OutputPath)
                                </MudText>
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText>Нет данных. Запустите обработку файлов.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<MudOverlay Visible="@_isProcessing" LockScroll="true">
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    <MudText Typo="Typo.h6" Class="mt-4">Обработка файлов...</MudText>
</MudOverlay>