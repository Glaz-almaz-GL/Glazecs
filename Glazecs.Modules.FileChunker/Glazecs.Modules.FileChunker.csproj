  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources\Languages\FileChunkerResources.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>FileChunkerResources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>



</Project>
