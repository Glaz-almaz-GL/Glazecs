@using Glazecs.Modules.FileChunker.Abstractions.Interfaces
@using Glazecs.Modules.FileChunker.Abstractions.Models
@using Glazecs.Shared.Core.Extensions
@using Glazecs.Shared.UI.Components
@using MudBlazor
@page "/modules/file-chunker/document_chunker"

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudGrid Spacing="4">

        <!-- ЛЕВАЯ КОЛОНКА: Настройки -->
        <MudItem xs="12" md="8">
            <MudCard Outlined="true" Class="h-100">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-4">@L["PageTitle"]</MudText>

                    <!-- Блок 1: Выбор модулей и правил -->
                    <MudText Typo="Typo.subtitle1" Class="mb-2">@L["ModulesAndRulesTitle"]</MudText>

                    <MudSelect T="IFileChunker"
                               MultiSelection="true"
                               @bind-SelectedValues="SelectedChunkers"
                               Label="@L["SelectChunkersLabel"]"
                               Variant="Variant.Outlined"
                               Disabled="@_isProcessing"
                               Class="mb-4"
                               ToStringFunc="@(chunker => $"{chunker.Name} ({string.Join(", ", chunker.SupportedExtensions)})")">
                        @foreach (var chunker in FileChunkers)
                        {
                            <MudSelectItem Value="@chunker">
                                @($"{chunker.Name} ({string.Join(", ", chunker.SupportedExtensions)})")
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudGrid>
                        @foreach (var state in RuleStates)
                        {
                            <MudItem xs="12" sm="6">
                                <MudSwitch T="bool"
                                           @bind-Value="state.IsEnabled"
                                           Label="@state.Rule.Name"
                                           Disabled="@_isProcessing"
                                           Color="Color.Primary">
                                    <MudTooltip Text="@state.Rule.Description" Placement="Placement.Top">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="ml-2" />
                                    </MudTooltip>
                                </MudSwitch>

                                @if (state.IsEnabled)
                                {
                                    <div class="mt-2 pl-4" style="border-left: 2px solid var(--mud-palette-primary);">
                                        @* Динамический рендеринг редактора *@
                                        @if (TryGetEditorComponentType(state.Rule, out var editorType))
                                        {
                                            <DynamicComponent Type="@editorType"
                                                              Parameters="@(new Dictionary<string, object?>
                                                              {
                                                                  ["Rule"] = state.Rule,
                                                                  ["OnChanged"] = EventCallback.Factory.Create(this, () => StateHasChanged())
                                                              })" />
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Дополнительная настройка не требуется.
                                            </MudText>
                                        }
                                    </div>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                    <MudDivider Class="my-4" />

                    <!-- Блок 2: Пути и Параметры -->
                    <MudText Typo="Typo.subtitle1" Class="mb-3">@L["PathsSectionTitle"]</MudText>

                    <PathPickerComponent @bind-Value="_sourceDirectory"
                                         IsFolder="true"
                                         Label="@L["SourceDirectoryLabel"]"
                                         Placeholder="@L["SourceDirectoryPlaceholder"]"
                                         TooltipText="@L["SourceDirectoryHelper"]"
                                         Icon="@Icons.Material.Filled.FolderOpen"
                                         IconStyle="width: 56px; height: 56px;"
                                         Disabled="@_isProcessing" />

                    <PathPickerComponent @bind-Value="_outputDirectory"
                                         IsFolder="true"
                                         Label="@L["OutputDirectoryLabel"]"
                                         Placeholder="@L["OutputDirectoryPlaceholder"]"
                                         TooltipText="@L["OutputDirectoryHelper"]"
                                         Icon="@Icons.Material.Filled.CreateNewFolder"
                                         IconStyle="width: 56px; height: 56px;"
                                         Disabled="@_isProcessing" />

                    <MudGrid Class="mt-2">
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="long"
                                             @bind-Value="_maxChunkSizeMB"
                                             Label="@L["MaxChunkSizeLabel"]"
                                             Min="1"
                                             Variant="Variant.Outlined"
                                             Disabled="@_isProcessing" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudCheckBox T="bool"
                                         @bind-Value="_scanSubfolders"
                                         Label="@L["ScanSubfoldersLabel"]"
                                         Color="Color.Primary"
                                         Disabled="@_isProcessing" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="_headerTemplate"
                                  Label="@L["HeaderTemplateLabel"]"
                                  Placeholder="@L["HeaderTemplatePlaceholder"]"
                                  Lines="3"
                                  MaxLines="3"
                                  Variant="Variant.Outlined"
                                  Disabled="@_isProcessing"
                                  Class="mt-4" />

                    <!-- Блок 3: Кнопки действий -->
                    <MudStack Row="true" Spacing="2" Class="mt-6 justify-end">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.FolderSpecial"
                                   OnClick="ScanSourceFolder"
                                   Disabled="@(_isProcessing || string.IsNullOrWhiteSpace(_sourceDirectory) || SelectedChunkers.Count == 0)">
                            @L["ScanButton"]
                        </MudButton>

                        @if (!_isProcessing)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       OnClick="ProcessFiles"
                                       Disabled="@(_selectedFiles.Count == 0 || string.IsNullOrWhiteSpace(_outputDirectory))">
                                @L["ProcessButton"]
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Error"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       OnClick="CancelProcessing">
                                @L["CancelButton"]
                            </MudButton>
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ПРАВАЯ КОЛОНКА: Файлы и Результаты -->
        <MudItem xs="12" md="4">
            <MudCard Outlined="true" Class="h-100 d-flex flex-column mb-4">
                <MudCardContent Class="flex-grow-0">
                    <MudText Typo="Typo.h6">
                        @L["FoundFilesTitle"]
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-2">@_selectedFiles.Count</MudChip>
                    </MudText>
                </MudCardContent>
                <MudDivider />
                <MudCardContent Class="pa-0 flex-grow-1" Style="overflow: hidden;">
                    @if (_selectedFiles.Any())
                    {
                        <MudDataGrid T="SelectedFileInfo" Items="_selectedFiles" Hover="true" Striped="true" Dense="true" Elevation="0" Style="max-height: 300px; overflow-y: auto;">
                            <Columns>
                                <PropertyColumn Property="x => x.Name" Title="@L["ColumnFileName"]" CellClass="text-truncate" />
                                <TemplateColumn Title="@L["ColumnSize"]">
                                    <CellTemplate>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.Size.ToHumanReadableSize()</MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       Disabled="@_isProcessing"
                                                       OnClick="@(() => RemoveFile(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center" style="height: 200px;">
                            <MudText Typo="Typo.body2"
                                     Color="Color.Secondary"
                                     Class="text-center">@L["NoFilesFound"]
                            </MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>

            <MudCard Outlined="true" Class="d-flex flex-column">
                <MudCardContent Class="flex-grow-0">
                    <MudText Typo="Typo.h6">@L["ResultsTitle"]</MudText>
                </MudCardContent>
                <MudDivider />
                <MudCardContent Class="pa-0 flex-grow-1" Style="overflow: hidden;">
                    <MudDataGrid T="ChunkResult"
                                 Items="_results"
                                 Hover="true"
                                 Striped="true"
                                 Dense="true"
                                 Loading="@_isProcessing"
                                 Style="max-height: 300px; overflow-y: auto;">
                        <Columns>
                            <PropertyColumn Property="x => x.OutputFileName"
                                            Title="@L["ColumnFileName"]"
                                            CellClass="text-truncate" />

                            <TemplateColumn Title="@L["ColumnSize"]">
                                <CellTemplate>@context.Item.SizeInBytes.ToHumanReadableSize()</CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>